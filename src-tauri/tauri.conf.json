{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CacheBar",
  "version": "0.1.0",
  "identifier": "com.cachebar.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CacheBar",
        "width": 380,
        "height": 620,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["windowBackground"],
          "radius": 26,
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "icons/icon.png"
    ]
  }
}
